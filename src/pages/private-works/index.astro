---
import Layout from '../../layouts/Layout.astro';
import privateWorksData from '../../data/private-works.json';

const { pageTitle, pageSubtitle, pageDescription, sections } = privateWorksData;
---

<Layout title="Private Practice - Alex Morris" theme="light">
  <a href="/" class="back-nav">&larr; Home</a>

  <div class="logo-header">
    <a href="/"><img src="/logo-dark.svg" alt="Strat Scraps" /></a>
  </div>

  <main style="padding-top: 6rem;">
    <header style="text-align: center; padding: 2rem;">
      <p class="nav-text" style="color: #666; margin-bottom: 1rem;"
         data-cms="private-works" data-cms-path="pageSubtitle">
        {pageSubtitle}
      </p>
      <h1 class="heading-primary"
          data-cms="private-works" data-cms-path="pageTitle">
        {pageTitle}
      </h1>
      <p style="color: #666; max-width: 500px; margin: 1rem auto; line-height: 1.6;"
         data-cms="private-works" data-cms-path="pageDescription">
        {pageDescription}
      </p>
    </header>

    <div class="section" style="max-width: 600px;">
      {sections.map((section, sectionIdx) => (
        <div class="accordion-item">
          <button
            class="accordion-header"
            data-accordion={section.id}
            aria-expanded="false"
          >
            <span data-cms="private-works" data-cms-path={`sections.${sectionIdx}.title`}>
              {section.title}
            </span>
            <span class="accordion-icon">+</span>
          </button>
          <div class="accordion-content" id={section.id}>
            <div style="padding-bottom: 1.5rem; line-height: 1.8;">
              {section.id === 'clients' && section.clients ? (
                <ul class="client-list">
                  {section.clients.map((client, clientIdx) => (
                    <li class="client-item">
                      <button class="client-toggle" aria-expanded="false">
                        <span data-cms="private-works"
                              data-cms-path={`sections.${sectionIdx}.clients.${clientIdx}.name`}>
                          {client.name}
                        </span>
                        <span class="client-icon">+</span>
                      </button>
                      <p class="client-description"
                         data-cms="private-works"
                         data-cms-path={`sections.${sectionIdx}.clients.${clientIdx}.description`}>
                        {client.description}
                      </p>
                    </li>
                  ))}
                </ul>
              ) : section.id === 'offering' ? (
                <>
                  <ul style="padding-left: 1.5rem;">
                    {section.content.split(', ').map((item) => (
                      <li data-cms="private-works"
                          data-cms-path={`sections.${sectionIdx}.content`}>
                        {item}
                      </li>
                    ))}
                  </ul>
                  <a href="/private-works/offerings" class="offering-menu-link">
                    Ways of working &rarr;
                  </a>
                </>
              ) : (
                <p data-cms="private-works"
                   data-cms-path={`sections.${sectionIdx}.content`}>
                  {section.content}
                </p>
              )}
            </div>
          </div>
        </div>
      ))}
    </div>
  </main>

  <a href="mailto:alex@stratscraps.com" class="contact-link">Contact</a>

  <script is:inline define:vars={{ _cmsData: privateWorksData, _cmsFile: 'private-works' }}>
    window.__cms = window.__cms || {};
    window.__cms[_cmsFile] = _cmsData;
  </script>
</Layout>

<script>
  document.querySelectorAll('.client-toggle').forEach(button => {
    button.addEventListener('click', () => {
      const li = button.parentElement;
      const isOpen = li?.classList.contains('open');
      if (isOpen) {
        li.classList.remove('open');
        button.setAttribute('aria-expanded', 'false');
        button.querySelector('.client-icon').textContent = '+';
      } else {
        li.classList.add('open');
        button.setAttribute('aria-expanded', 'true');
        button.querySelector('.client-icon').textContent = '−';
      }
    });
  });

  document.querySelectorAll('.accordion-header').forEach(button => {
    button.addEventListener('click', () => {
      const accordionId = button.getAttribute('data-accordion');
      const content = document.getElementById(accordionId);
      const icon = button.querySelector('.accordion-icon');
      const isOpen = content?.classList.contains('open');

      document.querySelectorAll('.accordion-content').forEach(el => {
        el.classList.remove('open');
      });
      document.querySelectorAll('.accordion-icon').forEach(el => {
        el.textContent = '+';
      });
      document.querySelectorAll('.accordion-header').forEach(el => {
        el.setAttribute('aria-expanded', 'false');
      });

      if (!isOpen && content) {
        content.classList.add('open');
        if (icon) icon.textContent = '−';
        button.setAttribute('aria-expanded', 'true');
      }
    });
  });
</script>

<style>
  .logo-header {
    position: fixed;
    top: 2rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 100;
  }

  .logo-header img {
    width: 50px;
    height: auto;
  }

  .accordion-header {
    background: none;
    border: none;
    width: 100%;
    text-align: left;
    font-family: inherit;
    color: inherit;
  }

  .client-list {
    list-style: none;
    padding: 0;
  }

  .client-item {
    border-bottom: 1px solid #eee;
  }

  .client-toggle {
    background: none;
    border: none;
    width: 100%;
    text-align: left;
    font-family: inherit;
    color: inherit;
    padding: 0.75rem 0;
    cursor: pointer;
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: inherit;
  }

  .client-icon {
    font-size: 1rem;
    opacity: 0.5;
  }

  .client-description {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.3s ease, padding 0.3s ease;
    padding: 0;
    color: #666;
    line-height: 1.6;
  }

  .client-item.open .client-description {
    max-height: 100px;
    padding-bottom: 0.75rem;
  }

  .offering-menu-link {
    display: inline-block;
    margin-top: 1.25rem;
    margin-left: 1.5rem;
    font-size: 14px;
    letter-spacing: 0.02em;
    border-bottom: 1px solid rgba(0, 0, 0, 0.25);
    transition: color 200ms, border-color 200ms;
  }

  .offering-menu-link:hover {
    color: var(--color-accent);
    border-color: var(--color-accent);
  }
</style>
