---
import Layout from '../../layouts/Layout.astro';
import offeringsData from '../../data/offerings.json';

const { pageTitle, pageSubtitle, pageIntro, groups } = offeringsData;
---

<Layout title="Offerings - Alex Morris" theme="light">
  <a href="/private-works" class="back-nav">← Private Practice</a>

  <div class="logo-header">
    <a href="/"><img src="/logo-dark.svg" alt="Strat Scraps" /></a>
  </div>

  <main style="padding-top: 6rem;">
    <header style="text-align: center; padding: 2rem;">
      <p class="nav-text" style="color: #666; margin-bottom: 1rem;">
        {pageSubtitle}
      </p>
      <h1 class="heading-primary">{pageTitle}</h1>
      <p style="color: #666; max-width: 500px; margin: 1rem auto; line-height: 1.6;">
        {pageIntro}
      </p>
    </header>

    <div class="section" style="max-width: 640px;">
      {groups.map((group) => (
        <section class="menu-group">
          <h2 class="section-title">{group.label}</h2>
          {group.items.map((item) => (
            <article class="offering">
              <div class="offering-head">
                <h3 class="offering-name">{item.name}</h3>
                <span class="offering-price">{item.price}</span>
              </div>
              {item.meta && <p class="offering-meta">{item.meta}</p>}
              <p class="offering-desc">{item.description}</p>
            </article>
          ))}
        </section>
      ))}

      <p class="menu-foot">
        Not sure which fits? <a href="mailto:alex@stratscraps.com">Tell me where you're stuck →</a>
      </p>
    </div>
  </main>

  <a href="mailto:alex@stratscraps.com" class="contact-link">Contact</a>
</Layout>

<style>
  .logo-header {
    position: fixed;
    top: 2rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 100;
  }

  .logo-header img {
    width: 50px;
    height: auto;
  }

  .menu-group {
    margin-bottom: 3.5rem;
  }

  .offering {
    padding: 1.75rem 0;
    border-bottom: 1px solid rgba(0, 0, 0, 0.08);
  }

  .menu-group .offering:last-child {
    border-bottom: none;
  }

  .offering-head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1.5rem;
  }

  .offering-name {
    font-size: 18px;
    font-weight: 400;
    letter-spacing: 0.02em;
  }

  .offering-price {
    font-size: 18px;
    font-weight: 500;
    white-space: nowrap;
  }

  .offering-meta {
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: #999;
    margin-top: 0.4rem;
  }

  .offering-desc {
    font-size: 14px;
    color: #666;
    line-height: 1.7;
    margin-top: 0.85rem;
    max-width: 54ch;
  }

  .menu-foot {
    margin-top: 1rem;
    font-size: 14px;
    color: #666;
  }

  .menu-foot a {
    border-bottom: 1px solid rgba(0, 0, 0, 0.25);
    transition: border-color 200ms, color 200ms;
  }

  .menu-foot a:hover {
    color: var(--color-accent);
    border-color: var(--color-accent);
  }
</style>
